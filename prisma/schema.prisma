generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid()) @db.VarChar(30)
  email     String   @unique @db.VarChar(191)
  password  String   @db.VarChar(255)
  name      String   @db.VarChar(100)
  role      String   @default("admin") @db.VarChar(20)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductCategory {
  id           String                       @id @default(cuid()) @db.VarChar(30)
  slug         String                       @unique @db.VarChar(191)
  order        Int                          @default(0)
  isActive     Boolean                      @default(true)
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  translations ProductCategoryTranslation[]
  products     Product[]
}

model ProductCategoryTranslation {
  id         String @id @default(cuid()) @db.VarChar(30)
  categoryId String @db.VarChar(30)
  locale     String @db.VarChar(5)
  name       String @db.VarChar(255)

  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
}

model Product {
  id           String               @id @default(cuid()) @db.VarChar(30)
  slug         String               @unique @db.VarChar(191)
  categoryId   String?              @db.VarChar(30)
  isActive     Boolean              @default(true)
  showOnHome   Boolean              @default(false)
  homeImage    String?              @db.VarChar(500)
  order        Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  category     ProductCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  translations ProductTranslation[]
  models       ProductModel[]
  images       ProductImage[]
  catalogs     ProductCatalog[]

  @@index([categoryId])
}

model ProductTranslation {
  id               String  @id @default(cuid()) @db.VarChar(30)
  productId        String  @db.VarChar(30)
  locale           String  @db.VarChar(5)
  slug             String? @db.VarChar(191)
  name             String  @db.VarChar(255)
  shortDescription String? @db.VarChar(160)
  description      String  @db.Text
  features         String? @db.Text

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([slug, locale])
  @@index([locale])
}

model ProductModel {
  id           String                    @id @default(cuid()) @db.VarChar(30)
  productId    String                    @db.VarChar(30)
  order        Int                       @default(0)
  product      Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  translations ProductModelTranslation[]

  @@index([productId])
}

model ProductModelTranslation {
  id          String @id @default(cuid()) @db.VarChar(30)
  modelId     String @db.VarChar(30)
  locale      String @db.VarChar(5)
  name        String @db.VarChar(255)
  description String @db.Text

  model ProductModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, locale])
  @@index([locale])
}

model ProductImage {
  id        String  @id @default(cuid()) @db.VarChar(30)
  productId String  @db.VarChar(30)
  url       String  @db.VarChar(500)
  altTr     String? @db.VarChar(255)
  altEn     String? @db.VarChar(255)
  order     Int     @default(0)
  isMain    Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductCatalog {
  id        String  @id @default(cuid()) @db.VarChar(30)
  productId String  @db.VarChar(30)
  title     String  @db.VarChar(255)
  url       String  @db.VarChar(500)
  fileSize  String? @db.VarChar(50)
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Application {
  id           String                   @id @default(cuid()) @db.VarChar(30)
  slug         String                   @unique @db.VarChar(191)
  image        String?                  @db.VarChar(500)
  isActive     Boolean                  @default(true)
  order        Int                      @default(0)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  translations ApplicationTranslation[]
}

model ApplicationTranslation {
  id            String @id @default(cuid()) @db.VarChar(30)
  applicationId String @db.VarChar(30)
  locale        String @db.VarChar(5)
  name          String @db.VarChar(255)
  description   String @db.Text

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, locale])
  @@index([locale])
}

model Page {
  id           String            @id @default(cuid()) @db.VarChar(30)
  slug         String            @unique @db.VarChar(191)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  translations PageTranslation[]
}

model PageTranslation {
  id        String  @id @default(cuid()) @db.VarChar(30)
  pageId    String  @db.VarChar(30)
  locale    String  @db.VarChar(5)
  title     String  @db.VarChar(255)
  content   String  @db.LongText
  metaTitle String? @db.VarChar(255)
  metaDesc  String? @db.Text

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
  @@index([locale])
}

model CompletedProject {
  id        String   @id @default(cuid()) @db.VarChar(30)
  titleTr   String   @db.Text
  titleEn   String?  @db.Text
  sourceTr  String   @db.VarChar(255) // e.g. "TÜBİTAK 1507 – 2010"
  sourceEn  String?  @db.VarChar(255) // e.g. "TUBITAK 1507 – 2010"
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid()) @db.VarChar(30)
  fullName  String   @db.VarChar(200)
  titleTr   String   @db.VarChar(255)
  titleEn   String?  @db.VarChar(255)
  image     String?  @db.VarChar(500)
  type      String   @db.VarChar(20) // "expert" | "consultant"
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model ContactSubject {
  id           String                      @id @default(cuid()) @db.VarChar(30)
  order        Int                         @default(0)
  isActive     Boolean                     @default(true)
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  translations ContactSubjectTranslation[]
}

model ContactSubjectTranslation {
  id        String @id @default(cuid()) @db.VarChar(30)
  subjectId String @db.VarChar(30)
  locale    String @db.VarChar(5)
  label     String @db.VarChar(255)

  subject ContactSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([subjectId, locale])
  @@index([locale])
}

model ContactMessage {
  id           String   @id @default(cuid()) @db.VarChar(30)
  name         String   @db.VarChar(100)
  organization String   @db.VarChar(255)
  email        String   @db.VarChar(191)
  phone        String?  @db.VarChar(30)
  subject      String   @db.VarChar(255)
  message      String?  @db.Text
  kvkkConsent  Boolean  @default(false)
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
}

